# === ELEVENLABS VOICE NAMES ===
# Usar NOMBRES de voz, NO UUIDs
# Docs: https://elevenlabs.io/docs/text-to-speech/voices

## Voces Masculinas (Español/Inglés)
VOICE_MALE_1="Adam"      # Profesional, claro ⭐
VOICE_MALE_2="Josh"      # Amigable, casual
VOICE_MALE_3="Arnold"    # Serio, autoritario
VOICE_MALE_4="Bill"      # Narrativo, calmado
VOICE_MALE_5="Antoni"    # Versátil, natural

## Voces Femeninas (Español/Inglés)
VOICE_FEMALE_1="Rachel"   # Profesional, clara ⭐ (DEFAULT)
VOICE_FEMALE_2="Domi"     # Joven, energética
VOICE_FEMALE_3="Bella"    # Suave, cálida
VOICE_FEMALE_4="Elli"     # Narración, documental
VOICE_FEMALE_5="Gigi"     # Joven, expresiva

## Voces para Personajes
VOICE_NARRATOR="Thomas"   # Maduro, serio
VOICE_YOUNG="Gigi"        # Joven, expresiva

# Voice ID por defecto (recomendado para Cornelio)
DEFAULT_VOICE="Adam"

# === USO EN SCRIPT ===
# ./avatar_video.sh --tts <imagen> <voice_name> "<texto>" [output]
#
# Ejemplo Cornelio (voz profesional masculina):
# ./avatar_video.sh --tts avatar.jpg Adam "Hola, soy Cornelio, tu CEO Virtual" /tmp/video.mp4
#
# Ejemplo con voz femenina:
# ./avatar_video.sh --tts avatar.jpg Rachel "Bienvenido a Cornelio.app" /tmp/video.mp4

# === PARÁMETROS ELEVENLABS ===
# stability: 0.5 (0-1, más alto = más consistente, menos expresivo)
# similarity_boost: 0.75 (0-1, más alto = más parecido a la voz original)
# speed: 1.0 (0.7-1.2, <1 más lento, >1 más rápido)

# === SCRIPT PRINCIPAL ===
# /root/.openclaw/workspace-magnum/scripts/avatar_video.sh

